# Paperless-ngx API Configuration
PAPERLESS_API_ENDPOINT=http://localhost:8000
PAPERLESS_API_TOKEN=your-api-token-here

# Optional: Single Visual LLM for BOTH OCR and suggestions.
# If all 3 VISUAL_LLM_* variables are set, they take precedence and
# OCR_LLM_* / TEXT_LLM_* are ignored.
VISUAL_LLM_ENDPOINT=http://your-visual-llm-server:8000/v1
VISUAL_LLM_MODEL_NAME=your-visual-llm-model-name
VISUAL_LLM_TOKEN=your-visual-llm-token
VISUAL_LLM_CONTEXT_LENGTH=12000
VISUAL_LLM_RESERVED_TOKENS=1500

# Batch Processing Concurrency
BATCH_PREP_MAX_CONCURRENCY=4
BATCH_OCR_CONSUMERS=2
BATCH_SUGGESTION_CONSUMERS=2

# Home Assistant scanner automation
SCAN_DEVICE_ID=your-scanner-device-id
SCAN_CMD_TEMPLATE=scanimage -d {device} --resolution 300 {mode_args} --format=png --output-file {output}
SCAN_MODE_MAP=single:bw,double:color
SCAN_MODE_ARGS_MAP=bw:--mode Gray,color:--mode Color
SCAN_FINALIZE_HANDLER=1_single
SCAN_FINALIZE_HANDLER_DOUBLE=1_double
PDF_MERGE_CMD_TEMPLATE=img2pdf {inputs} -o {output}
AUTOMATION_SUGGESTION_TRIGGER_TOKENS=3000
EMAIL_ATTACHMENT_MAX_BYTES=10485760

# Optional email mapping by initiating handler
# Format: handler:email,handler:email
HA_HANDLER_EMAIL_MAP=2_single:accounting@example.com,3_single:hr@example.com

# OCR LLM Configuration (used when VISUAL_LLM_* is not fully set)
OCR_LLM_ENDPOINT=http://your-ocr-llm-server:8000/v1
OCR_LLM_MODEL_NAME=your-ocr-model-name
OCR_LLM_TOKEN=your-ocr-token
OCR_LLM_MAX_TOKENS=500
OCR_LOG_RAW_PAYLOAD=false

# Text LLM Configuration (used when VISUAL_LLM_* is not fully set)
TEXT_LLM_ENDPOINT=http://your-text-llm-server:8000/v1
TEXT_LLM_MODEL_NAME=your-text-model-name
TEXT_LLM_TOKEN=your-text-token

# Phoenix Configuration
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
PORT=4000
PHX_HOST=localhost
